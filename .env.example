# ── UNLOCK-01 environment variables ──────────────────────────────
# Copy this file to .env for local testing, or paste each value
# into Railway → your UNLOCK-01 service → Variables.

PORT=8080

# DropsTab — covers both the unlock calendar (SUGGEST FROM DROPSTAB button)
# and tokenomics (market cap, FDV, supply). One key, one subscription,
# replaces what used to be a separate CoinGecko key.
# Sign up: dropstab.com/products/commercial-api — auth is a Bearer token.
DROPSTAB_API_KEY=

# Optional — only needed for wallet-transfer tracing (step 5).
# Free signup at etherscan.io/apis. One key now covers Ethereum, BSC,
# and 60+ other EVM chains via Etherscan's unified API V2 — you do NOT
# need a separate BscScan key, that system was retired in 2025.
ETHERSCAN_API_KEY=

# HERALD mail — same pattern as SUPREME-LEADER's alert system.
# Use a Gmail App Password (myaccount.google.com/apppasswords),
# not your normal Gmail password.
HERALD_GMAIL_USER=
HERALD_GMAIL_APP_PASSWORD=
HERALD_RECIPIENT=

# Optional — enables the "Include AI-sourced holder lookup" checkbox.
# Uses Claude (Anthropic API) with web search to read a token's holder list
# off a block explorer page. This is a best-effort LLM read of a webpage,
# NOT a verified structured API response — always labeled "unverified" in
# the UI. Costs API credits per lookup and is noticeably slower than the
# rest of the app, so it's opt-in per scan, not automatic.
ANTHROPIC_API_KEY=
# Optional — defaults to claude-haiku-4-5-20251001 (cheaper/faster). Set to
# a stronger model (e.g. claude-sonnet-5) if holder lookups come back
# unparseable or inaccurate too often.
CLAUDE_HOLDER_MODEL=
